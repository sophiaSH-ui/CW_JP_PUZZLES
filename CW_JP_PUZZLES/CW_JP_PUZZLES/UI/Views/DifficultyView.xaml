<UserControl x:Class="CW_JP_PUZZLES.UI.Views.DifficultyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBgDeep}">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

        <TextBlock Text="[ SELECT DIFFICULTY ]"
                   FontFamily="Resources/Fonts/#Press Start 2P"
                   FontSize="16"
                   Foreground="{StaticResource BrushCream}"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 16"/>

        <TextBlock Text="{Binding GameName}"
                   FontFamily="Resources/Fonts/#Press Start 2P"
                   FontSize="11"
                   Foreground="{StaticResource BrushPink}"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 40"/>

        <Border Background="{StaticResource BrushBgPanel}"
                BorderBrush="{StaticResource BrushBlueShadow}"
                BorderThickness="3"
                Padding="48 32">
            <StackPanel>
                <RadioButton IsChecked="{Binding IsEasy}"
                             Foreground="{StaticResource BrushCream}"
                             FontFamily="Resources/Fonts/#Press Start 2P"
                             FontSize="10"
                             Margin="0 0 0 20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="EASY"
                                   Foreground="{StaticResource BrushCream}"
                                   FontFamily="Resources/Fonts/#Press Start 2P"
                                   FontSize="10"
                                   Width="120"/>
                        <TextBlock Text="5 × 5"
                                   Foreground="{StaticResource BrushTextDim}"
                                   FontFamily="Resources/Fonts/#Press Start 2P"
                                   FontSize="10"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton IsChecked="{Binding IsHard}"
                             Foreground="{StaticResource BrushCream}"
                             FontFamily="Resources/Fonts/#Press Start 2P"
                             FontSize="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="HARD"
                                   Foreground="{StaticResource BrushCream}"
                                   FontFamily="Resources/Fonts/#Press Start 2P"
                                   FontSize="10"
                                   Width="120"/>
                        <TextBlock Text="7 × 7"
                                   Foreground="{StaticResource BrushTextDim}"
                                   FontFamily="Resources/Fonts/#Press Start 2P"
                                   FontSize="10"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 32 0 0">
            <Button Content="[ START ]"
                    Command="{Binding StartCommand}"
                    Style="{StaticResource PixelButtonAccent}"
                    Margin="12 0"/>
            <Button Content="[ BACK ]"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource PixelButton}"
                    Margin="12 0"/>
        </StackPanel>

    </StackPanel>
</UserControl>