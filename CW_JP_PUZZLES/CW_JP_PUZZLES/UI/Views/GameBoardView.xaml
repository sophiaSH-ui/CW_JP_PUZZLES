<UserControl x:Class="CW_JP_PUZZLES.UI.Views.GameBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CW_JP_PUZZLES.UI.ViewModels"
             Background="{StaticResource BrushBgDeep}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0 0 0 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding GameName}"
                       FontFamily="Resources/Fonts/#Press Start 2P"
                       FontSize="14"
                       Foreground="{StaticResource BrushPink}"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="TIME"
                           FontFamily="Resources/Fonts/#Press Start 2P"
                           FontSize="8"
                           Foreground="{StaticResource BrushTextDim}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding TimeDisplay}"
                           FontFamily="Resources/Fonts/#Press Start 2P"
                           FontSize="20"
                           Foreground="{StaticResource BrushCream}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <TextBlock Text="MOVES"
                           FontFamily="Resources/Fonts/#Press Start 2P"
                           FontSize="8"
                           Foreground="{StaticResource BrushTextDim}"
                           HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding MoveCount}"
                           FontFamily="Resources/Fonts/#Press Start 2P"
                           FontSize="20"
                           Foreground="{StaticResource BrushCream}"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource BrushBlueShadow}"
                BorderThickness="3"
                Width="{Binding BoardPixelSize}"
                Height="{Binding BoardPixelSize}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                SnapsToDevicePixels="True">

            <ItemsControl ItemsSource="{Binding Cells}"
                          Width="{Binding BoardPixelSize}"
                          Height="{Binding BoardPixelSize}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding GridSize}"
                                     Columns="{Binding GridSize}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Width" Value="64"/>
                        <Setter Property="Height" Value="64"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CellViewModel}">
                        <Button Width="64"
                                Height="64"
                                Command="{Binding LeftClickCommand}"
                                SnapsToDevicePixels="True">
                            <Button.InputBindings>
                                <MouseBinding MouseAction="RightClick"
                                              Command="{Binding RightClickCommand}"/>
                            </Button.InputBindings>

                            <Grid>
                                <Ellipse Width="36" Height="36"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Fill" Value="{StaticResource BrushGold}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasBulb}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasBulb}" Value="True"/>
                                                        <Condition Binding="{Binding HasError}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Fill" Value="Red"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <Ellipse Width="52" Height="52"
                                         Stroke="{StaticResource BrushGold}"
                                         StrokeThickness="3"
                                         Fill="Transparent"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCircled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontFamily="Resources/Fonts/#Press Start 2P">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DisplayValue}"/>
                                            <Setter Property="Foreground" Value="{StaticResource BrushCream}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ClueValue}" Value="">
                                                    <Setter Property="Text" Value="{Binding DisplayValue}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsWall}" Value="True">
                                                    <Setter Property="Text" Value="{Binding WallNumberText}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource BrushBgCell}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Root"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{StaticResource BrushBorder}"
                                                        BorderThickness="2"
                                                        SnapsToDevicePixels="True">
                                                    <Grid>
                                                        <Rectangle Fill="{Binding RegionColor}" 
                                                                   Opacity="0.4" 
                                                                   IsHitTestVisible="False"/>
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsIlluminated}" Value="True">
                                                        <Setter TargetName="Root" Property="Background"
                                                                Value="{StaticResource BrushBlueShadow}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsWall}" Value="True">
                                                        <Setter TargetName="Root" Property="Background"
                                                                Value="{StaticResource BrushDarkBrown}"/>
                                                        <Setter TargetName="Root" Property="BorderBrush"
                                                                Value="{StaticResource BrushBorderBright}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsBlackened}" Value="True">
                                                        <Setter TargetName="Root" Property="Background"
                                                                Value="{StaticResource BrushDarkBrown}"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="BorderBrush"
                                                                Value="{StaticResource BrushPink}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Root" Property="Background"
                                                                Value="{StaticResource BrushPurple}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 20 0 0">
            <Button Content="[ NEW ]"
                    Command="{Binding NewGameCommand}"
                    Style="{StaticResource PixelButtonSmall}"
                    Margin="8 0"/>
            <Button Content="[ RESET ]"
                    Command="{Binding ResetCommand}"
                    Style="{StaticResource PixelButtonSmall}"
                    Margin="8 0"/>
            <Button Content="[ MENU ]"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource PixelButtonAccent}"
                    FontSize="8"
                    Padding="10 6"
                    Margin="8 0"/>
        </StackPanel>
    </Grid>
</UserControl>