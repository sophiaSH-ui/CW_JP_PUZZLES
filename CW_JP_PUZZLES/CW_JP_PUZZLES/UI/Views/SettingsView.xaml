<UserControl x:Class="CW_JP_PUZZLES.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBgDeep}">

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="420">

        <TextBlock Text="[ SETTINGS ]"
                   FontFamily="Resources/Fonts/#Press Start 2P"
                   FontSize="20"
                   Foreground="{StaticResource BrushCream}"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 40"/>

        <Border Background="{StaticResource BrushBgPanel}"
                BorderBrush="{StaticResource BrushBlueShadow}"
                BorderThickness="3"
                Padding="32 24">
            <StackPanel>

                <DockPanel Margin="0 0 0 20" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="MUSIC"
                               FontFamily="Resources/Fonts/#Press Start 2P"
                               FontSize="9"
                               Foreground="{StaticResource BrushTextDim}"
                               VerticalAlignment="Center"/>
                    <CheckBox DockPanel.Dock="Right"
                              IsChecked="{Binding IsMusicEnabled}"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <TextBlock Text="MUSIC VOLUME"
                           FontFamily="Resources/Fonts/#Press Start 2P"
                           FontSize="8"
                           Foreground="{StaticResource BrushTextDim}"
                           Margin="0 0 0 8"/>
                <Slider Minimum="0" Maximum="1"
                        Value="{Binding MusicVolume}"
                        IsEnabled="{Binding IsMusicEnabled}"
                        Margin="0 0 0 24"/>

                <DockPanel Margin="0 0 0 20" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="SOUND FX"
                               FontFamily="Resources/Fonts/#Press Start 2P"
                               FontSize="9"
                               Foreground="{StaticResource BrushTextDim}"
                               VerticalAlignment="Center"/>
                    <CheckBox DockPanel.Dock="Right"
                              IsChecked="{Binding IsSfxEnabled}"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <TextBlock Text="FX VOLUME"
                           FontFamily="Resources/Fonts/#Press Start 2P"
                           FontSize="8"
                           Foreground="{StaticResource BrushTextDim}"
                           Margin="0 0 0 8"/>
                <Slider Minimum="0" Maximum="1"
                        Value="{Binding SfxVolume}"
                        IsEnabled="{Binding IsSfxEnabled}"/>

            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 32 0 0">
            <Button Content="[ SAVE ]"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PixelButtonAccent}"
                    Margin="12 0"/>
            <Button Content="[ BACK ]"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource PixelButton}"
                    Margin="12 0"/>
        </StackPanel>

    </StackPanel>
</UserControl>