<Application x:Class="CW_JP_PUZZLES.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CW_JP_PUZZLES.UI.ViewModels"
             xmlns:v="clr-namespace:CW_JP_PUZZLES.UI.Views"
             StartupUri="UI/Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/PixelColors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/CellStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:MainMenuViewModel}">
                <v:MainMenuView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DifficultyViewModel}">
                <v:DifficultyView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GameViewModel}">
                <v:GameBoardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ResultViewModel}">
                <v:ResultView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <v:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>