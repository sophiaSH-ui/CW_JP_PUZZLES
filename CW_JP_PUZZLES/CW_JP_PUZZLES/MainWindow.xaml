<Window x:Class="CW_JP_PUZZLES.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CW_JP_PUZZLES.UI.ViewModels"
        Title="JAPANESE PUZZLES"
        Width="700" Height="760"
        MinWidth="700" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBgDeep}"
        RenderOptions.BitmapScalingMode="NearestNeighbor"
        SnapsToDevicePixels="True">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <ContentControl Content="{Binding CurrentViewModel}"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"/>
</Window>